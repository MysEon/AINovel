# ── 应用配置 ──────────────────────────────────
APP_ENV=dev                # dev | test | prod
APP_DEBUG=true
APP_APP_NAME=AINovel API
APP_APP_VERSION=0.2.0

# ── 认证配置 ──────────────────────────────────
AUTH_SECRET_KEY=your-secret-key-at-least-32-characters-long
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── 数据库配置 ─────────────────────────────────
# 本地开发 (SQLite)
DB_URL=sqlite+aiosqlite:///./ainovel.db
DB_SYNC_URL=sqlite:///./ainovel.db
# 生产环境 (PostgreSQL)
# DB_URL=postgresql+asyncpg://user:pass@localhost:5432/ainovel
# DB_SYNC_URL=postgresql://user:pass@localhost:5432/ainovel
DB_ECHO=false

# ── CORS 配置 ──────────────────────────────────
# JSON 数组格式
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
